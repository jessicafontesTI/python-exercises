frase = str(input('Digite uma Frase: ')).strip() .upper()
palavra = frase.split()
junto = ''.join(palavra)
leitura = junto[: : -1]
if leitura == junto:
    print('Essa frase é um Políndromo')
else:
    print('Essa frase não é um Políndromo')
